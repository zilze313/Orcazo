# --- Database (Postgres) ---
# Local: spin up with `docker run -d --name startify-pg -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16`
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/startify?schema=public"

# --- Session crypto ---
# Generate with: openssl rand -hex 32
SESSION_SECRET="replace-me-with-a-long-random-hex-string-at-least-32-bytes"

# --- AffiliateNetwork upstream ---
AFFILIATENETWORK_BASE_URL="https://api.affiliatenetwork.com"
# Sane defaults; tweak if upstream rate-limits us
AFFILIATENETWORK_TIMEOUT_MS="15000"

# --- Admin bootstrap ---
# On first run, an admin row is seeded from these. Subsequent runs use the DB row.
ADMIN_BOOTSTRAP_EMAIL="admin@startify.local"
ADMIN_BOOTSTRAP_PASSWORD="change-me-immediately"

# --- Public ---
NEXT_PUBLIC_APP_NAME="Startify"
