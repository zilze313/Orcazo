// Orcazo schema. Models the data Orcazo owns; AffiliateNetwork remains
// the source of truth for campaigns, earnings, posts.
//
// Two-email model:
//   - publicEmail = what the creator sees and types at /login
//   - proxyEmail  = email registered on AffiliateNetwork, owned by the admin.
//     The OTP lands in admin's inbox; admin relays it to the creator.
//   - The Allowlist row maps publicEmail → proxyEmail.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum SignupStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum PayoutMethod {
  BANK
  CRYPTO
  PAYPAL
}

enum PayoutStatus {
  REQUESTED
  IN_PROGRESS
  PAID
  CANCELLED
  REJECTED
}

enum ReferralClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RepostSubmissionStatus {
  PENDING
  /// Legacy "looked at it" status from before approve/reject existed.
  REVIEWED
  APPROVED
  REJECTED
}

enum RepostCollabStatus {
  REQUESTED
  INVITED
  ACCEPTED
  APPROVED
  REJECTED
}

enum RepostPayoutStatus {
  REQUESTED
  IN_PROGRESS
  PAID
  CANCELLED
  REJECTED
}

model Allowlist {
  id               String    @id @default(cuid())
  // Public-facing email — what the creator types at /login.
  // (Column name kept as `email` to avoid destructive rename; treated as publicEmail in code.)
  email            String    @unique
  // The email actually registered on AffiliateNetwork. Nullable until admin connects it.
  proxyEmail       String?
  proxyConnectedAt DateTime?
  note             String?
  createdAt        DateTime  @default(now())
  createdBy        String?
  createdByAdmin   Admin?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  // OTP automation: each proxy Gmail forwards to this address (e.g. alice@orcazo.com).
  // Cloudflare Email Worker catches it, POSTs to /api/inbound-email, and we store the code here.
  inboundAddress String? // set by admin; must be unique per creator
  pendingOtp     String? // latest OTP extracted from an inbound email
  pendingOtpAt   DateTime? // when the OTP arrived (used for TTL checks)

  // Idle-proxy reclamation: set when we email the creator a "log in or lose access"
  // warning. The reclaim cron detaches the proxy 48h later if they're still idle.
  // Cleared automatically once they're no longer eligible (logged back in / earned).
  reclaimWarningSentAt DateTime?

  @@index([email])
  @@index([proxyEmail])
  @@index([inboundAddress])
}

/// Pool of AffiliateNetwork emails the admin owns. When approving a creator
/// signup, admin picks one of these to "connect" to the creator's public email.
model ManagedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  note      String?
  createdAt DateTime @default(now())

  @@index([email])
}

model Employee {
  id                       String    @id @default(cuid())
  email                    String    @unique // public email
  affiliateNetworkToken    String
  affiliateNetworkCookies  String?   @db.Text
  affiliateNetworkPublicId String?
  firstName                String?
  lastName                 String?
  bioVerificationCode      String?
  cachedBalance            Decimal?  @db.Decimal(12, 2)
  /// Most recent dashboard summary, cached so admin views + payout gates don't
  /// need a live upstream call. These store the REAL (un-multiplied),
  /// baseline-adjusted figures — i.e. only money made after the proxy was
  /// connected. The creator-facing multiplier is applied at response time, not here.
  ///   cachedWaitingPayment = upstream waitingPayment − baseline   (approved, in transit)
  ///   cachedWaitingReview  = upstream waitingReview  − baseline   (pending approval)
  ///   cachedPaid           = upstream totalPaid      − baseline   (settled to admin)
  cachedWaitingPayment     Decimal?  @db.Decimal(12, 2)
  cachedWaitingReview      Decimal?  @db.Decimal(12, 2)
  cachedPaid               Decimal?  @db.Decimal(12, 2)
  cachedSummaryAt          DateTime?
  /// Raw upstream totals captured the first time this creator loads their
  /// dashboard.  Used to zero-out pre-connection history so creators only see
  /// activity from the day their account was connected.
  baselineTotalPaid        Decimal?  @db.Decimal(14, 4)
  baselineWaitingPayment   Decimal?  @db.Decimal(14, 4)
  baselineWaitingReview    Decimal?  @db.Decimal(14, 4)
  baselineCapturedAt       DateTime?
  lastLoginAt              DateTime?
  lastSyncedAt             DateTime?
  createdAt                DateTime  @default(now())
  /// When true, the baseline isolation is bypassed: the creator sees all
  /// historical submissions and earnings, including pre-connection history.
  showFullHistory          Boolean   @default(false)
  /// JSON array of social-account publicIds that existed on the upstream
  /// account when the creator first loaded their dashboard (baseline capture).
  /// These are hidden from the creator unless showFullHistory is enabled.
  baselineSocialIds        String?
  adminNotes               String?   @db.Text

  sessions                   Session[]
  submissions                SubmissionAudit[]
  payouts                    PayoutRequest[]
  messages                   ChatMessage[]
  referralClaims             ReferralClaim[]
  customCampaignApplications CustomCampaignApplication[]
  notifications              Notification[]
  repostSubscriptions        RepostSubscription[]
  repostSubmissions          RepostSubmission[]
  repostCredits              RepostCredit[]
  repostPayoutRequests       RepostPayoutRequest[]
  repostCollabRequests       RepostCollabRequest[]

  @@index([email])
  @@index([lastLoginAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([firstName])
  @@index([cachedBalance(sort: Desc)])
}

model Session {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  ipAddress  String?
  userAgent  String?

  @@index([employeeId])
  @@index([expiresAt])
}

model Admin {
  id               String         @id @default(cuid())
  email            String         @unique
  passwordHash     String
  role             AdminRole      @default(ADMIN)
  /// JSON array of permission strings. SUPER_ADMIN ignores this field (has all permissions).
  permissions      Json           @default("[]")
  createdAt        DateTime       @default(now())
  sessions         AdminSession[]
  allowlistEntries Allowlist[]
}

model AdminSession {
  id        String   @id @default(cuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([expiresAt])
}

model SubmissionAudit {
  id               String   @id @default(cuid())
  employeeId       String
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  campaignPublicId String
  campaignName     String
  linkSubmitted    String   @db.Text
  upstreamStatus   Int
  upstreamSuccess  Boolean
  upstreamMessage  String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([employeeId, createdAt(sort: Desc)])
  @@index([campaignPublicId])
  @@index([createdAt(sort: Desc)])
  @@index([upstreamSuccess, createdAt(sort: Desc)])
  @@index([campaignName])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  details   Json?
  createdAt DateTime @default(now())

  @@index([adminId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

/// Admin-created referral codes. Creators can enter one of these at signup.
model ReferralCode {
  id        String   @id @default(cuid())
  code      String   @unique
  note      String?
  createdAt DateTime @default(now())

  @@index([code])
}

/// Creator self-signup requests submitted from the public marketing site.
/// On approval, an Allowlist row is created and a ManagedEmail is bound to it.
model CreatorSignupRequest {
  id                  String       @id @default(cuid())
  publicEmail         String       @unique // dedupes; one request per email
  fullName            String
  whatsapp            String
  /// Array of { platform: 'tiktok'|'instagram'|..., handle: string }
  socialAccounts      Json
  status              SignupStatus @default(PENDING)
  rejectionReason     String?
  connectedProxyEmail String? // set when approved
  referralCode        String? // optional code entered at signup
  createdAt           DateTime     @default(now())
  reviewedAt          DateTime?
  reviewedBy          String?
  ipAddress           String?

  @@index([status, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([publicEmail])
}

/// A login-code relay request. Created when a creator hits /api/auth/send-code.
/// Admin sees it, retrieves the OTP from the proxy inbox, pastes it here and
/// clicks "Send code" — Resend delivers it to the creator's public email under
/// Orcazo branding, so the creator never sees the proxy email address.
model LoginRequest {
  id          String    @id @default(cuid())
  publicEmail String
  proxyEmail  String
  status      String    @default("PENDING") // PENDING | RELAYED | EXPIRED
  createdAt   DateTime  @default(now())
  relayedAt   DateTime?

  @@index([status, createdAt(sort: Desc)])
  @@index([publicEmail, createdAt(sort: Desc)])
}

/// Web-push subscription from an admin device (browser).
/// Stored so the server can push notifications when new signups / login
/// requests arrive. One row per browser session; uniqueness by endpoint.
model AdminPushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique @db.Text
  p256dh    String   @db.Text
  auth      String
  createdAt DateTime @default(now())
  lastUsed  DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

/// Admin-managed rules for campaigns. Completely replaces upstream rules so
/// affiliatenetwork.com is never exposed to creators.
model CampaignRules {
  id               String   @id @default(cuid())
  campaignPublicId String   @unique
  campaignName     String
  /// Rich-text HTML content written via the admin WYSIWYG editor.
  rulesHtml        String   @default("") @db.Text
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  @@index([campaignPublicId])
}

/// Creator payout requests. Status workflow:
///   REQUESTED → PAID (admin approves with amount) or → REJECTED (admin enters reason)
model PayoutRequest {
  id              String       @id @default(cuid())
  employeeId      String
  employee        Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  method          PayoutMethod
  /// JSON details: bank ⇒ { iban, swift, holderName, bankName }; crypto ⇒ { network, address }
  details         Json
  /// Snapshot of totalWaitingPayment at request time (post-multiplier). For audit.
  amountAtRequest Decimal      @db.Decimal(12, 2)
  status          PayoutStatus @default(REQUESTED)
  notes           String?      @db.Text
  /// Amount admin actually paid (may differ from amountAtRequest)
  amountPaid      Decimal?     @db.Decimal(12, 2)
  /// Penalty = amountAtRequest − amountPaid (auto-computed when admin approves)
  penalty         Decimal?     @db.Decimal(12, 2)
  /// Admin note: rejection reason or other comment
  adminNote       String?      @db.Text
  createdAt       DateTime     @default(now())
  inProgressAt    DateTime?
  paidAt          DateTime?
  /// When the creator saw (or dismissed) the payout-approved celebration
  /// card. Null on a PAID payout means the celebration is still pending.
  celebratedAt    DateTime?
  cancelledAt     DateTime?
  rejectedAt      DateTime?

  @@index([employeeId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

/// Admin-controlled visibility for upstream campaigns.
/// If a campaign's publicId has a row with hidden=true it is stripped from
/// every creator's campaign list.  Campaigns with no row (or hidden=false)
/// are visible as normal.
model CampaignVisibility {
  id               String   @id @default(cuid())
  campaignPublicId String   @unique
  campaignName     String
  hidden           Boolean  @default(false)
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  @@index([campaignPublicId])
  @@index([hidden])
}

/// Admin-written announcements shown to creators on the Updates tab.
model Announcement {
  id          String   @id @default(cuid())
  title       String   @db.VarChar(200)
  contentHtml String   @db.Text
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

/// Admin overrides for campaign display name and rates.
/// When a creator views campaigns, these values replace the upstream defaults.
model CampaignOverride {
  id               String   @id @default(cuid())
  campaignPublicId String   @unique
  displayName      String?
  displayCpm       Decimal? @db.Decimal(10, 4)
  displayBase      Decimal? @db.Decimal(10, 4)
  displayCap       Decimal? @db.Decimal(10, 4)
  updatedAt        DateTime @updatedAt

  @@index([campaignPublicId])
}

/// Support chat messages between creators and admin.
/// fromAdmin=false → creator sent it; fromAdmin=true → admin sent it.
/// readAt is set by the receiving party when they open the conversation.
model ChatMessage {
  id                String    @id @default(cuid())
  employeeId        String
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fromAdmin         Boolean   @default(false)
  content           String    @db.Text
  /// Supabase Storage public URL for an attached image.
  mediaUrl          String?   @db.Text
  /// MIME type of the attached media (e.g. "image/jpeg").
  mediaType         String?
  readAt            DateTime?
  /// For admin → creator messages: when the unread notification email becomes due
  /// (set to createdAt + 5 minutes on send). null = no notification scheduled.
  notifyEmailAt     DateTime?
  /// Set when we actually send the unread-message email — idempotency guard.
  notifyEmailSentAt DateTime?
  createdAt         DateTime  @default(now())

  @@index([employeeId, createdAt(sort: Asc)])
  @@index([fromAdmin, readAt])
  @@index([createdAt(sort: Desc)])
  /// Speeds up the cron lookup for due notifications.
  @@index([notifyEmailAt, notifyEmailSentAt])
}

/// Campaign showcase videos displayed in the homepage infinite carousel.
model HomepageVideo {
  id        String   @id @default(cuid())
  url       String   @db.Text
  title     String?  @db.VarChar(200)
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, order])
}

/// Key-value store for admin-configurable platform settings.
/// Known keys: earningsMultiplier, autoLoginEnabled, referralThreshold, referralReward
model AdminSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

/// A creator's claim for their referral reward once the threshold is met.
model ReferralClaim {
  id            String              @id @default(cuid())
  employeeId    String
  employee      Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  status        ReferralClaimStatus @default(PENDING)
  /// Referral count at time of claim
  referralCount Int
  /// Threshold that was active at time of claim
  threshold     Int
  /// Reward amount configured at time of claim
  rewardAmount  Decimal             @db.Decimal(12, 2)
  adminNote     String?             @db.Text
  createdAt     DateTime            @default(now())
  resolvedAt    DateTime?

  @@index([employeeId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

/// Captures inbound emails that the OTP extractor couldn't parse — typically
/// Gmail forwarding-confirmation requests or unrelated messages. Surfaced in
/// the admin panel so the admin can click confirmation links without digging
/// through Vercel logs.
model InboundMailEvent {
  id          String    @id @default(cuid())
  /// Inbound address the email was sent to (e.g. alice@orcazo.com)
  to          String
  fromAddress String?
  subject     String?
  /// Gmail forwarding-confirmation URL if one was found in the body
  confirmUrl  String?   @db.Text
  /// ~1KB readable preview of the decoded email body
  bodySnippet String?   @db.Text
  /// Set when admin clicks dismiss. Auto-purged after 30 days regardless of state.
  dismissedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([dismissedAt, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

/// Log of admin bulk email broadcasts sent to all creators.
model BroadcastEmail {
  id             String   @id @default(cuid())
  subject        String
  bodyHtml       String   @db.Text
  recipientCount Int
  createdAt      DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

/// Public contact-form submissions. Available to anyone, even without an account.
/// Status workflow: NEW → RESOLVED (admin replied) or DISMISSED (spam / no action).
model ContactMessage {
  id          String               @id @default(cuid())
  name        String               @db.VarChar(120)
  email       String               @db.VarChar(254)
  subject     String               @db.VarChar(200)
  message     String               @db.Text
  /// Set when the sender is a logged-in creator (linked Employee.id), else null.
  employeeId  String?
  ipAddress   String?              @db.VarChar(64)
  userAgent   String?              @db.Text
  status      ContactMessageStatus @default(NEW)
  adminNote   String?              @db.Text
  resolvedAt  DateTime?
  dismissedAt DateTime?
  createdAt   DateTime             @default(now())

  @@index([status, createdAt(sort: Desc)])
  @@index([email])
  @@index([createdAt(sort: Desc)])
}

enum ContactMessageStatus {
  NEW
  RESOLVED
  DISMISSED
}

/// Admin-created "house" campaigns shown alongside upstream ones to make the
/// platform look like it has its own roster. Applications stay PENDING for the
/// configured delay (default 48h), then a daily cron flips them to
/// AUTO_REJECTED with the global rejection reason from AdminSetting.
/// publicId is always prefixed `cc_` so it can be detected in merged feeds.
model CustomCampaign {
  id                   String    @id @default(cuid())
  publicId             String    @unique
  name                 String    @db.VarChar(200)
  iconUrl              String?   @db.Text
  description          String?   @db.Text
  rulesHtml            String?   @db.Text
  /// Per-1000-views rate displayed to creators (post-commission display value).
  rpm                  Decimal   @db.Decimal(10, 2)
  base                 Decimal   @default(0) @db.Decimal(10, 2)
  cap                  Decimal   @db.Decimal(10, 2)
  threshold            Int       @default(1000)
  thresholdType        String    @default("views")
  platforms            String[]  @default([])
  languages            String[]  @default([])
  /// JSON array of { url, ordering?, platform? }
  examplesJson         Json      @default("[]")
  totalBudget          Decimal?  @db.Decimal(12, 2)
  budgetRemaining      Decimal?  @db.Decimal(12, 2)
  /// Fake "approval rate" shown on the card (0-100).
  approvalRate         Float?
  dateEnd              DateTime?
  inviteOnly           Boolean   @default(false)
  active               Boolean   @default(true)
  ordering             Int       @default(0)
  /// Hours an application must stay pending before the cron auto-rejects it.
  autoRejectDelayHours Int       @default(48)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  applications CustomCampaignApplication[]

  @@index([active, ordering])
  @@index([active, createdAt(sort: Desc)])
}

enum CustomCampaignApplicationStatus {
  PENDING
  AUTO_REJECTED
}

model CustomCampaignApplication {
  id               String                          @id @default(cuid())
  customCampaignId String
  customCampaign   CustomCampaign                  @relation(fields: [customCampaignId], references: [id], onDelete: Cascade)
  employeeId       String
  employee         Employee                        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  /// Social.publicId from upstream (we don't store Socials locally).
  socialPublicId   String
  socialPlatform   String
  socialHandle     String
  status           CustomCampaignApplicationStatus @default(PENDING)
  /// Snapshot of the rejection reason in effect when this app was auto-rejected.
  rejectionReason  String?                         @db.Text
  rejectedAt       DateTime?
  createdAt        DateTime                        @default(now())

  @@unique([customCampaignId, employeeId, socialPublicId])
  @@index([employeeId, customCampaignId])
  @@index([status, createdAt])
}

/// In-app notifications for creators. Feeds the bell menu in the creator shell.
model Notification {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type       String // payout_approved | payout_rejected | repost_new_post | repost_credit | system
  title      String
  body       String?
  url        String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([employeeId, readAt])
  @@index([employeeId, createdAt(sort: Desc)])
}

// =============================================================
// Reposting — a separate, real campaign type. Creators subscribe to admin-
// owned social accounts; admin logs new posts against those accounts; creators
// repost + submit proof; admin pays out of a fully separate wallet (never
// mixed with the upstream/AffiliateNetwork-derived balance).
// =============================================================

/// A repost program shown as a "Subscribe" card in the creator feed. Admin can
/// create multiple (e.g. one per niche/platform), each with its own roster of
/// source accounts.
model RepostCampaign {
  id          String   @id @default(cuid())
  publicId    String   @unique
  name        String   @db.VarChar(200)
  iconUrl     String?  @db.Text
  description String?  @db.Text
  rulesHtml   String?  @db.Text
  active      Boolean  @default(true)
  ordering    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sourceAccounts RepostSourceAccount[]

  @@index([active, ordering])
}

/// An admin-owned social account creators can subscribe to. When admin logs a
/// new post against this account, every subscriber is notified.
model RepostSourceAccount {
  id               String         @id @default(cuid())
  repostCampaignId String
  repostCampaign   RepostCampaign @relation(fields: [repostCampaignId], references: [id], onDelete: Cascade)
  platform         String
  handle           String         @db.VarChar(120)
  displayName      String?        @db.VarChar(160)
  profileUrl       String?        @db.Text
  avatarUrl        String?        @db.Text
  active           Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  subscriptions RepostSubscription[]
  posts         RepostPost[]

  @@index([repostCampaignId, active])
}

/// A creator "following" an admin source account. Instant, no approval — the
/// creator toggles this on/off freely.
model RepostSubscription {
  id              String              @id @default(cuid())
  employeeId      String
  employee        Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  sourceAccountId String
  sourceAccount   RepostSourceAccount @relation(fields: [sourceAccountId], references: [id], onDelete: Cascade)
  createdAt       DateTime            @default(now())

  @@unique([employeeId, sourceAccountId])
  @@index([sourceAccountId])
  @@index([employeeId])
}

/// Admin logs a new post published on a source account (just a URL + note).
/// Creating this row is what fires notifications to every subscriber.
model RepostPost {
  id              String              @id @default(cuid())
  sourceAccountId String
  sourceAccount   RepostSourceAccount @relation(fields: [sourceAccountId], references: [id], onDelete: Cascade)
  postUrl         String              @db.Text
  note            String?             @db.Text
  /// Which actions creators can take on this post.
  allowRepost     Boolean             @default(true)
  allowCollab     Boolean             @default(false)
  /// Instagram caps collaborators per post (currently 5 invitees) — this is
  /// the number of collab requests that can be accepted for this post.
  collabSlots     Int                 @default(5)
  createdAt       DateTime            @default(now())

  submissions    RepostSubmission[]
  collabRequests RepostCollabRequest[]

  @@index([sourceAccountId, createdAt(sort: Desc)])
}

/// A creator's proof that they reposted a given RepostPost. Required before
/// admin issues a credit — gives the admin an audit trail to review.
model RepostSubmission {
  id            String                 @id @default(cuid())
  repostPostId  String
  repostPost    RepostPost             @relation(fields: [repostPostId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  repostUrl     String                 @db.Text
  /// Self-reported by the creator — unverified, just a data point for admin.
  reportedViews Int?
  /// Self-reported follower count of the account that reposted — used to
  /// resolve the bounty tier; admin eyeballs it against the linked account.
  followers     Int?
  status        RepostSubmissionStatus @default(PENDING)
  /// Bounty credited on approval (tier-resolved, admin-adjustable).
  bountyPaid    Decimal?               @db.Decimal(12, 2)
  adminNote     String?                @db.Text
  createdAt     DateTime               @default(now())
  reviewedAt    DateTime?

  @@unique([repostPostId, employeeId])
  @@index([employeeId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

/// Admin-configurable bounty tiers by follower count. The applicable tier is
/// the highest minFollowers that is <= the creator's follower count.
model RepostBountyTier {
  id           String   @id @default(cuid())
  minFollowers Int
  repostBounty Decimal  @db.Decimal(12, 2)
  collabBounty Decimal  @db.Decimal(12, 2)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active, minFollowers])
}

/// A creator asking to be added as a collaborator on an admin post
/// (Instagram collab / equivalent). Flow:
/// REQUESTED → admin sends the invite from the platform app → INVITED →
/// creator accepts it in-app → ACCEPTED → admin verifies + credits → APPROVED.
model RepostCollabRequest {
  id           String             @id @default(cuid())
  repostPostId String
  repostPost   RepostPost         @relation(fields: [repostPostId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  platform     String?            @db.VarChar(40)
  /// The creator's handle the admin should send the collab invite to.
  handle       String             @db.VarChar(120)
  /// Self-reported follower count — used to resolve the bounty tier.
  followers    Int?
  status       RepostCollabStatus @default(REQUESTED)
  /// Bounty credited on approval (tier-resolved, admin-adjustable).
  bountyPaid   Decimal?           @db.Decimal(12, 2)
  adminNote    String?            @db.Text
  createdAt    DateTime           @default(now())
  invitedAt    DateTime?
  acceptedAt   DateTime?
  reviewedAt   DateTime?

  @@unique([repostPostId, employeeId])
  @@index([status, createdAt(sort: Desc)])
  @@index([employeeId, createdAt(sort: Desc)])
}

/// Admin-issued credit into a creator's repost wallet. This is the ONLY way
/// money enters the repost side — a discretionary judgment call (account size,
/// growth, repost consistency), not a formula. Never touches the main
/// upstream-derived balance.
model RepostCredit {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  amount     Decimal  @db.Decimal(12, 2)
  note       String   @db.Text
  createdAt  DateTime @default(now())

  @@index([employeeId, createdAt(sort: Desc)])
}

/// Creator payout request drawn ONLY from the repost wallet
/// (sum(RepostCredit) − sum(amountAtRequest of PAID requests)). Same
/// REQUESTED → IN_PROGRESS → PAID/REJECTED workflow as the main PayoutRequest,
/// but a fully separate table/balance so the two never mix.
model RepostPayoutRequest {
  id              String             @id @default(cuid())
  employeeId      String
  employee        Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  method          PayoutMethod
  details         Json
  amountAtRequest Decimal            @db.Decimal(12, 2)
  status          RepostPayoutStatus @default(REQUESTED)
  notes           String?            @db.Text
  amountPaid      Decimal?           @db.Decimal(12, 2)
  penalty         Decimal?           @db.Decimal(12, 2)
  adminNote       String?            @db.Text
  createdAt       DateTime           @default(now())
  inProgressAt    DateTime?
  paidAt          DateTime?
  cancelledAt     DateTime?
  rejectedAt      DateTime?

  @@index([employeeId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

/// A "featured payout" card shown in the homepage marquee. Fully
/// admin-curated — nothing here links back to a real employee, so no PII
/// can leak through the public endpoint.
model ShowcasePayout {
  id          String   @id @default(cuid())
  displayName String   @db.VarChar(80)
  handle      String?  @db.VarChar(80)
  platform    String?  @db.VarChar(40)
  amount      Decimal  @db.Decimal(12, 2)
  note        String?  @db.VarChar(160)
  /// Free-text label like "March 2026" — admin controls exactly what's shown.
  paidLabel   String?  @db.VarChar(40)
  active      Boolean  @default(true)
  ordering    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, ordering])
}

enum BrandRequestStatus {
  NEW
  CONTACTED
  CLOSED
}

/// Inbound "launch a campaign" request from a brand — public form, reviewed
/// in the admin panel. This is a lead, not an account.
model BrandCampaignRequest {
  id           String             @id @default(cuid())
  brandName    String             @db.VarChar(120)
  contactName  String             @db.VarChar(120)
  email        String             @db.VarChar(254)
  website      String?            @db.VarChar(300)
  campaignName String             @db.VarChar(160)
  /// Budget bracket in USD as picked on the form (e.g. "5000-10000").
  budget       String             @db.VarChar(40)
  /// Array of platform slugs the brand wants, e.g. ["tiktok","instagram"].
  platforms    Json?
  description  String?            @db.Text
  status       BrandRequestStatus @default(NEW)
  adminNote    String?            @db.Text
  ipAddress    String?            @db.VarChar(64)
  userAgent    String?            @db.Text
  createdAt    DateTime           @default(now())
  contactedAt  DateTime?
  closedAt     DateTime?

  @@index([status, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}
